# faiththruphysics-site .gitignore
# This repo is HTML/CSS/JS only — no media, no build artifacts

# Build scripts (local only, not deployed)
BUILD_SITE.ps1

# Backup files from Kimi edits
*.bak*
*.backup_*
_backups/

# OS junk
Thumbs.db
.DS_Store
desktop.ini

# Python cache (from local server testing)
__pycache__/
*.pyc

# Temp
*.tmp
*.log

# Clipboard artifacts
Clipboard Text.txt

# Large media files - hosted on R2 instead
*.mp4
*.m4a
*.wav
*.mp3
